---
import Bio from '@/components/about/bio.astro';
import Location from '@/components/about/location.astro';
import Contact from '@/components/contact.astro';
---

<div
	id="about-wrapper"
	class="pointer-events-none relative grid h-auto w-full auto-cols-[1fr] grid-cols-[1fr] grid-rows-[auto] gap-8 p-5 sm:h-screen sm:grid-cols-[1fr_1fr] sm:grid-rows-[auto_auto] sm:gap-10 sm:p-8 lg:grid-cols-[2fr_1fr] lg:grid-rows-[3fr_2fr] lg:gap-8 lg:p-6"
>
	<div
		id="about-box-bio"
		class="bg-primary text-primary-content pointer-events-auto relative grid auto-cols-[1fr] grid-flow-row grid-cols-[1fr] grid-rows-[auto_auto] gap-8 overflow-hidden rounded-2xl px-6 pt-12 pb-8 select-auto sm:gap-10 sm:rounded-3xl sm:p-12 xl:p-10"
	>
		<Bio />
	</div>

	<div
		id="about-box-location"
		class="grid-about-box pointer-events-auto min-h-[280px] !p-0 sm:min-h-[20vh] lg:min-h-[30vh]"
	>
		<Location />
	</div>

	<div
		id="about-box-contact"
		class="bg-primary text-primary-content pointer-events-auto relative flex flex-col overflow-hidden rounded-2xl sm:rounded-3xl"
	>
		<Contact />
	</div>
</div>

<style>
	@reference "../../styles/base.css";

	#about-box-bio {
		grid-area: 1 / 1 / 2 / 2;

		@media (width >= theme(--breakpoint-sm)) {
			grid-area: 1 / 1 / 2 / 3;
		}

		@media (width >= theme(--breakpoint-lg)) {
			grid-area: 1 / 1 / 2 / 2;
		}
	}

	#about-box-location {
		grid-area: 2 / 1 / 3 / 2;

		@media (width >= theme(--breakpoint-sm)) {
			grid-area: 2 / 1 / 3 / 2;
		}

		@media (width >= theme(--breakpoint-lg)) {
			grid-area: 2 / 1 / 3 / 2;
		}
	}

	#about-box-contact {
		grid-area: 3 / 1 / 4 / 2;

		@media (width >= theme(--breakpoint-sm)) {
			grid-area: 2 / 2 / 3 / 3;
		}

		@media (width >= theme(--breakpoint-lg)) {
			grid-area: 1 / 2 / 3 / 3;
		}
	}

	.grid-about-box {
		@apply text-base-content relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white p-10 text-sm;

		@media (width >= theme(--breakpoint-sm)) {
			@apply rounded-3xl;
		}
	}
</style>
