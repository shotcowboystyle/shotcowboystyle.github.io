---
import TestimonialCard from '@/components/testimonials/testimonial-card.astro';
import { getCollection } from 'astro:content';

const testimonials = await getCollection('testimonial');
const featured = testimonials.sort((a, b) => a.data.order - b.data.order)[0];

const stack = [
	'TypeScript',
	'React',
	'Vue',
	'Astro',
	'Node.js',
	'.NET',
	'GSAP',
	'Three.js',
	'Shopify',
	'Supabase',
	'Stripe',
	'Zapier',
];
---

<div class="flex flex-col gap-8 sm:gap-10">
	<h2
		id="bio-headline"
		class="mb-0 font-semibold sm:max-w-[18ch] sm:font-extrabold"
	>
		I’m Curtis, A full-stack developer based in Charleston, SC.
	</h2>

	<div class="flex flex-col gap-6">
		<p
			id="bio-description"
			class="text-base-content mb-0 font-sans text-base !leading-normal font-medium sm:text-xl sm:font-semibold xl:text-base"
		>
			Fifteen-plus years shipping scalable web work — product UI, marketing sites, and interactive
			brand pieces. Comfortable across the stack, senior-IC by preference, deadline-driven by habit.
		</p>

		<ul
			class="bio-stack flex flex-wrap items-center gap-2 sm:gap-3"
			aria-label="Selected stack"
		>
			{
				stack.map((tag) => (
					<li class="border-primary-content/40 rounded-full border px-3 py-1 font-sans text-xs font-semibold tracking-wide uppercase sm:text-sm">
						{tag}
					</li>
				))
			}
		</ul>
	</div>

	{
		featured && (
			<figure class="bio-quote border-primary-content/25 border-t pt-6 sm:pt-8">
				<blockquote class="mb-4">
					<TestimonialCard testimonial={featured} />
				</blockquote>
				<figcaption class="text-primary-content font-sans text-xs font-medium italic sm:text-sm">
					— placeholder. Real testimonials shipping when clients approve; for now, enjoy the mystery
					box.
				</figcaption>
			</figure>
		)
	}
</div>

<style>
	@media (width >= theme(--breakpoint-md)) and (hover: hover) and (pointer: fine) {
		#bio-headline {
			font-size: 4.5rem;
		}

		#bio-description {
			font-weight: 500 !important;
			font-size: 1.125em !important;
		}
	}
</style>
