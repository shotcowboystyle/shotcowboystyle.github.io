---
const items = [...Array(7)];
---

<ul
	class="transition-container js-loader-wrapper"
	id="transition-container"
	transition:persist
>
	{items.map(() => <li class="transition-container-list-item js-loader-item" />)}
</ul>

<style>
	@reference "../styles/base.css";

	.transition-container {
		@apply pointer-events-none fixed top-[-71vh] left-0 z-50 m-0 flex h-[200vh] rotate-45 overflow-x-hidden p-0 md:top-[-105vh] md:h-[300vh];
	}

	.transition-container-list-item {
		@apply odd:bg-primary even:bg-secondary w-[20vh] rounded-[200px] opacity-0 before:content-none md:w-[32vh];
	}
</style>
