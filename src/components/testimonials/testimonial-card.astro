---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	testimonial: CollectionEntry<'testimonial'>;
}

const { data } = Astro.props.testimonial;
---

<p
	class="testimonial-text my-4 text-base !leading-normal sm:text-xl lg:!text-sm lg:!leading-relaxed"
>
	{data.testimonial}
</p>

<div
	class="flex flex-row items-center justify-end justify-items-end self-end justify-self-end text-right md:mb-2 md:flex-col md:items-end"
>
	<div class="avatar order-2 ml-4 md:order-1 md:mb-2 md:ml-0">
		<div class="w-16 rounded-full">
			<Image
				src={data.avatar}
				widths={[72, 144, data.avatar.width]}
				class="rounded-circle"
				alt={data.name}
			/>
		</div>
	</div>

	<div class="mb-0 flex flex-col justify-end md:order-2">
		<div
			class="testimonial-name font-sans-serif mb-0 text-base leading-none font-bold uppercase sm:text-lg"
		>
			{data.name}
		</div>
		<div class="testimonial-byline -mt-1 text-xs leading-none sm:text-base lg:text-sm">
			{data.designation}, {data.companyName}
		</div>
	</div>
</div>

<style>
	@reference "../../styles/base.css";

	@media screen and (orientation: landscape) and (hover: none) {
		.testimonial-text {
			@apply mb-16;
		}
	}
</style>
