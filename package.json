{
	"name": "shotcowboystyle.github.io",
	"description": "Personal site for Curtis Blanton. Hooray! ✨",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"author": {
		"name": "Curtis Blanton",
		"url": "https://shotcowboystyle.github.io"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/shotcowboystyle/shotcowboystyle.github.io"
	},
	"license": "MIT",
	"scripts": {
		"postprepare": "lefthook install",
		"astro": "astro",
		"build": "astro build",
		"clean": "rm -rf .astro dist lighthouse node_modules pnpm-lock.yaml",
		"commit": "git-cz",
		"dev": "astro dev",
		"format:check": "prettier '**/*.{tsx,ts,mjs,cjs,js,json,css,yml,yaml,md,astro}' --check",
		"format:fix": "pnpm run format:check -w",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint .",
		"lint:code:fix": "pnpm run lint:code:check --fix",
		"lint:package:check": "npmPkgJsonLint .",
		"lint:packages:check": "pnpm dedupe --check",
		"lint:knip:check": "knip --config knip.config.mjs",
		"lint:spelling:check": "cspell lint './**/*.{tsx,ts,mjs,cjs,js,json,css,yml,yaml,md,astro}' --gitignore --cache",
		"lint:styles:check": "stylelint src/**/*.{astro,css} --cache --ignore-pattern .gitignore",
		"lint:styles:fix": "pnpm run lint:styles:check --fix",
		"preview": "astro preview",
		"tsc": "tsc",
		"test": "run-s test:e2e:*",
		"test:e2e": "run-s test:e2e:*",
		"test:e2e:accessibility": "playwright test e2e/tests/accessibility",
		"test:e2e:pages": "playwright test e2e/tests/pages",
		"test:e2e:performance": "playwright test e2e/tests/performance",
		"test:e2e:visual": "playwright test e2e/tests/visual",
		"test:playwright:codegen": "playwright codegen",
		"test:playwright:debug": "playwright test --debug",
		"test:playwright:ui": "playwright test --ui",
		"types:check": "astro sync && tsc --noEmit && astro check",
		"validate": "run-p format:check lint:check types:check test"
	},
	"dependencies": {
		"@astrojs/sitemap": "^3.7.3",
		"astro": "^6.4.8",
		"astro-svgs": "^1.2.2",
		"astro-sw": "^1.0.5",
		"cannon": "^0.6.2",
		"gsap": "^3.15.0",
		"lenis": "^1.3.25",
		"lottie-web": "^5.13.0",
		"maplibre-gl": "^5.24.0",
		"sharp": "^0.35.3",
		"split-type": "^0.3.4",
		"swiper": "^12.2.0",
		"three": "^0.185.1"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/ts-plugin": "^1.10.10",
		"@axe-core/playwright": "^4.12.1",
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@eslint/js": "^10.0.1",
		"@eslint/markdown": "^8.0.3",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@playwright/test": "^1.61.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "10.0.1",
		"@semantic-release/github": "^12.0.9",
		"@semantic-release/release-notes-generator": "^14.1.1",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/cannon": "^0.1.13",
		"@types/eslint": "^9.6.1",
		"@types/three": "^0.185.0",
		"@typescript-eslint/eslint-plugin": "^8.63.0",
		"@typescript-eslint/parser": "^8.63.0",
		"astro-compress": "2.4.1",
		"astro-critters": "^2.2.1",
		"astro-eslint-parser": "^1.4.0",
		"astro-purgecss": "^6.0.1",
		"ci-info": "^4.4.0",
		"commitizen": "^4.3.2",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"cspell": "^10.0.1",
		"cz-conventional-changelog": "^3.3.0",
		"daisyui": "^5.6.14",
		"eslint": "^10.6.0",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-import-x": "^4.17.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"globals": "^17.7.0",
		"knip": "^6.24.0",
		"lefthook": "2.1.9",
		"lighthouse": "^13.4.0",
		"npm-package-json-lint": "^10.4.1",
		"npm-package-json-lint-config-default": "^9.0.1",
		"npm-run-all2": "^8.0.4",
		"playwright": "^1.61.1",
		"playwright-lighthouse": "^4.0.0",
		"postcss": "^8.5.16",
		"postcss-html": "^1.8.1",
		"prettier": "^3.9.4",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup-plugin-analyzer": "^4.0.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"semantic-release": "25.0.5",
		"stylelint": "^17.14.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-hudochenkov": "^13.0.2",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-tailwindcss": "^1.0.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3"
	},
	"pnpm": {
		"overrides": {
			"lodash": ">=4.18.1"
		}
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
